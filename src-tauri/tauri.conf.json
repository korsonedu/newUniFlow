{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UniFlow",
  "version": "0.1.0",
  "identifier": "com.uniflow.timeline",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "UniFlow",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "devtools": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Education",
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
